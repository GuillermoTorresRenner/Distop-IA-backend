# Copy to .env (dev), .env.qa or render via secrets (QA_ENV_VARS / PROD_ENV_VARS).
# COMPOSE_PROJECT_NAME and PREFIX drive container_name and project namespace in docker compose.
COMPOSE_PROJECT_NAME=distop_ia_dev
PREFIX=distop_ia_dev

PORT=3000
JWT_SECRET=replace-me
NODE_ENV=dev

POSTGRES_USER=distop_ia
POSTGRES_PASSWORD=replace-me
DB_USER=distop_ia
DB_PASSWORD=replace-me
DB_NAME=distop_ia
DATABASE_URL=postgresql://distop_ia:replace-me@db:5432/distop_ia?schema=public

BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
