enum AttributeCategoryInfo {
  PHYSICAL
  SOCIAL
  MENTAL
}

/// Info de catálogo para los 9 atributos canónicos V20. El campo `key` matchea
/// el nombre de la columna en `Character` (strength, dexterity, …) para que el
/// frontend pueda referenciar el atributo desde la hoja por su key.
model AttributeInfo {
  id          String                @id @default(uuid())
  key         String                @unique
  name        String
  category    AttributeCategoryInfo
  description String?
  order       Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("attribute_info")
}

/// Info de catálogo para las habilidades V20 (Talentos / Técnicas / Conocimientos).
/// `key` es el slug interno (ej. "trato-con-animales") y `name` el nombre canónico
/// que se usa también como `CharacterAbility.name` y `DisciplinePower.rollAbility`.
/// Reusamos el enum `AbilityCategory` ya definido en Character.prisma.
model AbilityInfo {
  id          String          @id @default(uuid())
  key         String          @unique
  name        String          @unique
  category    AbilityCategory
  description String?
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("ability_info")
}

/// Info de catálogo para los niveles de salud (Magullado, Lastimado, …).
/// `key` matchea el sufijo de las columnas de salud en Character
/// (bruised, hurt, injured, wounded, mauled, crippled, incapacitated).
model HealthLevelInfo {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String   @unique
  penalty     Int      @default(0)
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("health_level_info")
}

/// Arquetipos compartidos entre Naturaleza y Conducta (Demeanor)
model Archetype {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  charactersAsNature   Character[] @relation("CharacterNature")
  charactersAsDemeanor Character[] @relation("CharacterDemeanor")

  @@map("archetypes")
}

/// Disciplinas base (Auspex, Celeridad, Dominación, etc.)
model Discipline {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  powers              DisciplinePower[]
  characterDisciplines CharacterDiscipline[]

  @@map("disciplines")
}

/// Poderes anidados bajo una Disciplina; un poder por nivel (1..5).
///
/// Mecánica codificada (cuando aplica):
///   - `bloodCost`: puntos de sangre que cuesta activar (0 = gratuito).
///   - `rollAttribute` + `rollAbility`: si el poder requiere una tirada
///     activa, qué claves del personaje (ej. "manipulation" + "Intimidación").
///     Si ambos son null el poder se considera pasivo / activación simple.
///   - `rollDifficulty`: dificultad por defecto cuando hay tirada. Por canon
///     V20 suele ser 6, pero algunos poderes específicos varían.
///   - `summary`: resumen corto para el tooltip (1-2 líneas). `description`
///     sigue siendo el texto largo del manual.
model DisciplinePower {
  id             String     @id @default(uuid())
  disciplineId   String
  discipline     Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  level          Int
  name           String
  description    String?

  /// Resumen corto para el tooltip de la mesa (versión condensada).
  summary        String?
  /// Puntos de sangre que cuesta activar. 0 = sin coste.
  bloodCost      Int        @default(0)
  /// Clave del atributo a usar en la tirada activa, en formato del modelo
  /// Character (ej. "manipulation", "strength", "perception"). Null = pasivo.
  rollAttribute  String?
  /// Nombre de la habilidad a usar en la tirada activa (ej. "Intimidación",
  /// "Empatía"). Si la "habilidad" es la propia disciplina, ponemos su
  /// nombre exacto (ej. "Dominación"). Null = pasivo o el roller usa solo el atributo.
  rollAbility    String?
  /// Dificultad por defecto cuando hay tirada activa. Default 6 si null.
  rollDifficulty Int?

  @@unique([disciplineId, level])
  @@index([disciplineId])
  @@map("discipline_powers")
}

enum MeritFlawKind {
  MERIT
  FLAW
}

/// Clanes y linajes del mundo VtM.
model Clan {
  id          String   @id @default(uuid())
  name        String   @unique
  sect        String?  // Camarilla / Sabbat / Anarchs / Linaje / Independiente
  description String?
  disciplines String?  // Disciplinas de clan separadas por coma (texto descriptivo)
  weakness    String?  // Debilidad de clan
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  characters Character[]

  @@map("clans")
}

/// Catálogo de Trasfondos canónicos V20 (Aliados, Contactos, Fama, …).
/// El nombre que se guarda en `CharacterBackground.name` puede coincidir
/// con uno de estos (caso recomendado) o ser un texto libre customizado
/// por el jugador (no hay FK; el front decide si renderiza como select
/// cerrado o como input libre). Si la entrada está en este catálogo, el
/// modal muestra su descripción narrativa.
model Background {
  id          String   @id @default(uuid())
  /// Slug interno en kebab-case (ej. "aliados", "contactos").
  key         String   @unique
  /// Nombre canónico en español (ej. "Aliados"). Se usa como label visible
  /// y como valor escrito en CharacterBackground.name al elegirlo.
  name        String   @unique
  /// Categoría opcional para agrupar en la UI (ej. "Social", "Material").
  category    String?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("backgrounds")
}

/// Catálogo de Méritos y Defectos.
/// `value` positivo para méritos, negativo para defectos (valor canónico VtM).
model MeritFlaw {
  id          String        @id @default(uuid())
  name        String        @unique
  kind        MeritFlawKind
  value       Int
  category    String?
  description String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  characterMeritFlaws CharacterMeritFlaw[]

  @@map("merits_flaws")
}
