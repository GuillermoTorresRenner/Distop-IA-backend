/// Posibles usos del punto de Voluntad gastado en una tirada V20.
enum WillpowerEffect {
  /// No se gastó voluntad.
  NONE
  /// Se gastó 1 punto para sumar 1 éxito automático (no removible por 1s).
  SUCCESS
  /// Se gastó 1 punto para anular el penalizador por heridas de esta tirada.
  WOUND
  /// Se gastaron 2 puntos: suma 1 éxito automático Y anula el penalizador.
  BOTH
}

/// Tirada de dados V20 ejecutada en una mesa.
/// Persistimos todas las tiradas (incluso las privadas) para histórico,
/// auditoría y replay.
model DiceRoll {
  id              String     @id @default(uuid())
  chronicleId     String
  chronicle       Chronicle  @relation(fields: [chronicleId], references: [id], onDelete: Cascade)
  userId          String
  user            Users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId     String?
  character       Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  /// Etiqueta libre que el usuario asigna (ej: "Percepción + Alerta").
  label           String?
  /// Cantidad de d10 base (atributo + habilidad + bonificadores).
  pool            Int
  /// Dificultad VtM V20. Por defecto 6.
  difficulty      Int        @default(6)
  /// Especialidad declarada en la habilidad: solo permitida si skillRating>=4.
  /// Cuando es true, cada 10 detona un dado extra que se relanza (1 = -1 éxito,
  /// 10 = nuevo dado extra encadenado). Los 10s NO doblan éxitos.
  specialty       Boolean    @default(false)
  /// Nivel de la habilidad declarada al momento de la tirada (1..5).
  /// Se persiste para auditar la regla de especialidad>=4.
  skillRating     Int?
  /// Snapshot del texto de la especialidad usada en esta tirada (markdown).
  /// Se persiste para que el historial muestre lo que el jugador tenía
  /// declarado en ese momento, aunque después lo edite. Sólo tiene sentido
  /// cuando specialty=true; en el resto de casos queda null.
  specialtyText   String?
  /// Compatibilidad: marca si se gastó algún punto de voluntad.
  /// La intención exacta se describe en los flags wpForSuccess/Wound/Reroll
  /// y en el campo derivado `willpowerEffect` (legacy).
  willpowerSpent  Boolean    @default(false)
  /// Voluntad: 1 punto por +1 éxito automático no removible por 1s.
  wpForSuccess    Boolean    @default(false)
  /// Voluntad: 1 punto para anular el penalizador por heridas.
  wpForWound      Boolean    @default(false)
  /// Voluntad: 1 punto para relanzar todos los dados que no fueron éxito
  /// una sola vez (los 1s del reroll restan éxitos como un fallo normal).
  wpForReroll     Boolean    @default(false)
  /// Compatibilidad legacy: combinación de SUCCESS/WOUND (no refleja REROLL).
  willpowerEffect WillpowerEffect @default(NONE)

  /// Penalizador por heridas que se aplicó a esta tirada (negativo o 0).
  /// Si wpForWound = true, este valor representa lo que hubiera sido el
  /// penalizador y se anula (no afecta al pool final).
  woundPenalty    Int        @default(0)

  /// Resultados crudos de cada dado del pool inicial (1..10).
  rolls           Int[]
  /// Dados extras lanzados por la regla de especialidad (cada 10 detona uno).
  /// Vacío si no hubo especialidad o ningún 10. Los 10s consecutivos
  /// encadenan más dados (la lista refleja el orden cronológico del rerroll).
  specialtyRerolls Int[]
  /// Dados extras lanzados por el reroll de voluntad (todos los fallos del
  /// pool inicial se relanzan una vez). Vacío si no se usó wpForReroll.
  willpowerRerolls Int[]
  /// Éxitos finales (tras restas y bonos).
  successes       Int
  /// True si el resultado fue una pifia (botch): 0 éxitos finales con al menos un 1.
  isBotch         Boolean    @default(false)

  /// Si false, solo el narrador y el autor ven el resultado en el broadcast.
  isPublic        Boolean    @default(true)

  /// De dónde se originó la tirada. Por ahora "DISCIPLINE" cuando el roller
  /// fue rellenado por activar un poder. Null para tiradas manuales o
  /// click-to-roll de atributo+habilidad.
  sourceKind      String?
  /// Etiqueta legible asociada al `sourceKind`. Para DISCIPLINE es el nombre
  /// de la disciplina (ej. "Dominación"). Renderizado como badge en el chat.
  sourceName      String?

  createdAt       DateTime   @default(now())

  @@index([chronicleId, createdAt])
  @@index([userId])
  @@map("dice_rolls")
}
