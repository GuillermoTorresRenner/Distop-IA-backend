/// Posibles usos del punto de Voluntad gastado en una tirada V20.
enum WillpowerEffect {
  /// No se gastó voluntad.
  NONE
  /// Se gastó 1 punto para sumar 1 éxito automático (no removible por 1s).
  SUCCESS
  /// Se gastó 1 punto para anular el penalizador por heridas de esta tirada.
  WOUND
  /// Se gastaron 2 puntos: suma 1 éxito automático Y anula el penalizador.
  BOTH
}

/// Tirada de dados V20 ejecutada en una mesa.
/// Persistimos todas las tiradas (incluso las privadas) para histórico,
/// auditoría y replay.
model DiceRoll {
  id              String     @id @default(uuid())
  chronicleId     String
  chronicle       Chronicle  @relation(fields: [chronicleId], references: [id], onDelete: Cascade)
  userId          String
  user            Users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId     String?
  character       Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  /// Etiqueta libre que el usuario asigna (ej: "Percepción + Alerta").
  label           String?
  /// Cantidad de d10 base (atributo + habilidad + bonificadores).
  pool            Int
  /// Dificultad VtM V20. Por defecto 6.
  difficulty      Int        @default(6)
  /// Especialidad: los 10s cuentan doble éxito.
  specialty       Boolean    @default(false)
  /// Compatibilidad: marca si se gastó algún punto de voluntad.
  /// La intención exacta se describe en `willpowerEffect`.
  willpowerSpent  Boolean    @default(false)
  /// Cómo se usó la voluntad gastada:
  ///   NONE    → no se gastó.
  ///   SUCCESS → suma 1 éxito automático no removible por 1s.
  ///   WOUND   → anula el penalizador por heridas en esta tirada.
  ///   BOTH    → gasta 2 puntos: suma 1 éxito y anula heridas.
  willpowerEffect WillpowerEffect @default(NONE)

  /// Penalizador por heridas que se aplicó a esta tirada (negativo o 0).
  /// Si willpowerEffect = WOUND o BOTH, este valor representa lo que
  /// hubiera sido el penalizador y se anula (no afecta al pool final).
  woundPenalty    Int        @default(0)

  /// Resultados crudos de cada dado (1..10).
  rolls           Int[]
  /// Éxitos finales (tras restas y doble por specialty + willpower).
  successes       Int
  /// True si el resultado fue una pifia (botch): 0 éxitos finales con al menos un 1.
  isBotch         Boolean    @default(false)

  /// Si false, solo el narrador y el autor ven el resultado en el broadcast.
  isPublic        Boolean    @default(true)

  createdAt       DateTime   @default(now())

  @@index([chronicleId, createdAt])
  @@index([userId])
  @@map("dice_rolls")
}
