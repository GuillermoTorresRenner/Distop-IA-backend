model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
