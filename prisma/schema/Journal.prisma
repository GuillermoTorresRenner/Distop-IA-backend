model ChronicleJournalEntry {
  id          String    @id @default(uuid())
  chronicleId String
  chronicle   Chronicle @relation(fields: [chronicleId], references: [id], onDelete: Cascade)
  authorId    String
  author      Users     @relation("ChronicleJournalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  body        String
  sessionDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([chronicleId])
  @@index([authorId])
  @@map("chronicle_journal_entries")
}

model CharacterJournalEntry {
  id          String     @id @default(uuid())
  chronicleId String
  chronicle   Chronicle  @relation(fields: [chronicleId], references: [id], onDelete: Cascade)
  authorId    String
  author      Users      @relation("CharacterJournalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  title       String
  body        String
  sessionDate DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([chronicleId, authorId])
  @@index([characterId])
  @@map("character_journal_entries")
}
