# Plantilla para el secret QA_ENV_VARS en GitHub Actions (no commitear valores reales).
COMPOSE_PROJECT_NAME=distop_ia_qa
PREFIX=distop_ia_qa

PORT=3000
JWT_SECRET=replace-me
NODE_ENV=qa

POSTGRES_USER=distop_ia
POSTGRES_PASSWORD=replace-me
DB_USER=distop_ia
DB_PASSWORD=replace-me
DB_NAME=distop_ia
# El backend habla con la DB por la red interna (servicio "db")
DATABASE_URL=postgresql://distop_ia:replace-me@db:5432/distop_ia?schema=public

BACKEND_URL=https://qa.distop-ia.example.com
FRONTEND_URL=https://qa.distop-ia.example.com

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
